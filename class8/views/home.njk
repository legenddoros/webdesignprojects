<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Upload Image</title>
  <style>
    body {
      margin: 0;
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #667eea, #764ba2);
      font-family: Arial, sans-serif;
    }

    .upload-card {
      background: white;
      padding: 2rem;
      border-radius: 16px;
      box-shadow: 0 10px 25px rgba(0,0,0,0.2);
      text-align: center;
      width: 300px;
    }

    h2 {
      margin-bottom: 1rem;
      color: #333;
    }

    input[type="file"] {
      margin: 1rem 0;
      padding: 0.5rem;
      border: 2px dashed #ccc;
      border-radius: 8px;
      width: 100%;
      cursor: pointer;
    }

    input[type="file"]:hover {
      border-color: #667eea;
    }

    button {
      background: #667eea;
      color: white;
      border: none;
      padding: 0.7rem 1.5rem;
      border-radius: 8px;
      cursor: pointer;
      font-size: 1rem;
      transition: 0.2s;
    }

    button:hover {
      background: #5a67d8;
      transform: translateY(-1px);
    }
  </style>
</head>
<body>

  <div class="upload-card">
    <h2>Upload Image</h2>

    <form action="/upload" method="post" enctype="multipart/form-data">
      <input type="file" name="myImage" required />
      <br />
      <button type="submit">Upload</button>
    </form>
  </div>

</body>
</html>
